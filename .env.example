# --- Zerodha Credentials (Legacy) ---
ZERODHA_USER_ID=your_zerodha_id
ZERODHA_API_KEY=your_zerodha_key
ZERODHA_API_SECRET=your_zerodha_secret
ZERODHA_ACCESS_TOKEN=your_zerodha_token

# --- Fyers Credentials (New) ---
FYERS_CLIENT_ID=your_client_id_app_id  # e.g., XV000000-100
FYERS_SECRET_KEY=your_secret_key
FYERS_REDIRECT_URI=http://localhost:3000
FYERS_USER_ID=your_fyers_id # e.g., XA1234
FYERS_ACCESS_TOKEN=your_fyers_access_token # Generated via script
FYERS_TOTP_KEY=optional_totp_key

# --- Data Providers ---
MARKETAUX_API_TOKEN=optional_token
EODHD_API_TOKEN=optional_token

# --- Database (Optional Override) ---
